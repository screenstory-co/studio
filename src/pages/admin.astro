<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CMS — Screenstory Studio</title>
</head>
<body>
  <div id="nc-root"></div>

  <script is:inline src="https://unpkg.com/decap-cms@3.6.2/dist/decap-cms.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const params = new URLSearchParams(window.location.search);
      const site = params.get('site');
      if (!site) {
        window.location.href = '/';
        return;
      }
      fetch('/api/config?site=' + encodeURIComponent(site))
        .then(function(resp) {
          if (!resp.ok) return resp.text().then(function(t) { throw new Error(t); });
          return resp.json();
        })
        .then(function(config) { CMS.init({ config }); })
        .catch(function(err) {
          console.error(err);
          document.body.innerHTML = '<div style="padding:2rem;font-family:sans-serif"><h2>Error loading CMS config</h2><pre>' + (err.message || err) + '</pre></div>';
        });
    });
  </script>
</body>
</html>
