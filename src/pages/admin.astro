<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CMS — Screenstory Studio</title>
</head>
<body>
  <div id="nc-root"></div>

  <script src="https://unpkg.com/decap-cms@3.6.2/dist/decap-cms.js"></script>
  <script>
    (async function() {
      const params = new URLSearchParams(window.location.search);
      const site = params.get('site');
      if (!site) {
        window.location.href = '/';
        return;
      }
      try {
        const resp = await fetch('/api/config?site=' + encodeURIComponent(site));
        if (!resp.ok) throw new Error(await resp.text());
        const config = await resp.json();
        CMS.init({ config });
      } catch (err) {
        console.error(err);
        document.body.innerHTML = '<div style="padding:2rem;font-family:sans-serif"><h2>Error loading CMS config</h2><pre>' + err.message + '</pre></div>';
      }
    })();
  </script>
</body>
</html>
